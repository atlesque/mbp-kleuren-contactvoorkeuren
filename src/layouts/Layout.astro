---
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Overzicht van de drie kleurtypen voor contactvoorkeuren in het Mijn Burgerprofiel." />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet" />
    <style>
      @import "tailwindcss";

      /* ── Design tokens (light mode defaults) ── */
      :root {
        --font-heading: 'DM Serif Display', Georgia, 'Times New Roman', serif;
        --font-body: 'DM Sans', system-ui, -apple-system, 'Segoe UI', sans-serif;
        --bg-start: #f4f4f6;
        --bg-mid: #eaeaef;
        --bg-end: #f4f4f6;
        --text-heading: #0d1117;
        --text-body: #3a3d44;
        --text-muted: #6b6e76;
        --text-dim: #8f929a;
        --surface: rgba(255, 255, 255, 0.85);
        --surface-border: rgba(0, 0, 0, 0.08);
        --surface-border-strong: rgba(0, 0, 0, 0.12);
        --callout-bg: rgba(0, 0, 0, 0.03);
        --callout-border: rgba(0, 0, 0, 0.08);
        --nav-bg: rgba(255, 255, 255, 0.75);
        --nav-border: rgba(0, 0, 0, 0.08);
        --pill-bg: rgba(0, 0, 0, 0.04);
        --pill-text: rgba(0, 0, 0, 0.5);
        --pill-border: rgba(0, 0, 0, 0.08);
        --table-stripe: rgba(0, 0, 0, 0.015);
        --table-border: rgba(0, 0, 0, 0.08);
        --link-color: #4a5568;
        --link-hover: #0d1117;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
        --shadow-md: 0 4px 16px rgba(0,0,0,0.08);
      }

      /* ── Dark mode overrides ── */
      .dark {
        --bg-start: #0d1b2a;
        --bg-mid: #1a3a5c;
        --bg-end: #0d1b2a;
        --text-heading: #ffffff;
        --text-body: rgba(255, 255, 255, 0.9);
        --text-muted: rgba(255, 255, 255, 0.55);
        --text-dim: rgba(255, 255, 255, 0.4);
        --surface: rgba(255, 255, 255, 0.06);
        --surface-border: rgba(255, 255, 255, 0.08);
        --surface-border-strong: rgba(255, 255, 255, 0.12);
        --callout-bg: rgba(255, 255, 255, 0.06);
        --callout-border: rgba(255, 255, 255, 0.1);
        --nav-bg: rgba(13, 27, 42, 0.8);
        --nav-border: rgba(255, 255, 255, 0.08);
        --pill-bg: rgba(255, 255, 255, 0.08);
        --pill-text: rgba(255, 255, 255, 0.5);
        --pill-border: rgba(255, 255, 255, 0.12);
        --table-stripe: rgba(255, 255, 255, 0.02);
        --table-border: rgba(255, 255, 255, 0.08);
        --link-color: rgba(255, 255, 255, 0.45);
        --link-hover: rgba(255, 255, 255, 0.85);
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.3);
        --shadow-md: 0 4px 16px rgba(0,0,0,0.35);
      }

      /* ── Animated gradient background ── */
      @keyframes gradientShift {
        0%   { background-position: 0% 50%; }
        50%  { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
      }

      body {
        background: linear-gradient(135deg, var(--bg-start), var(--bg-mid), var(--bg-end), var(--bg-mid), var(--bg-start));
        background-size: 400% 400%;
        animation: gradientShift 18s ease infinite;
        color: var(--text-body);
        transition: background 0.4s ease, color 0.3s ease;
      }

      /* ── Animations ── */
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .fade-in-up {
        opacity: 0;
        animation: fadeInUp 0.7s ease forwards;
      }

      .fade-in-up:nth-child(1) { animation-delay: 0.1s; }
      .fade-in-up:nth-child(2) { animation-delay: 0.2s; }
      .fade-in-up:nth-child(3) { animation-delay: 0.35s; }
      .fade-in-up:nth-child(4) { animation-delay: 0.5s; }
      .fade-in-up:nth-child(5) { animation-delay: 0.65s; }

      /* ── Legacy card classes (kept for reference, phase out with table) ── */
      .card-oranje {
        border-top: 4px solid #f97316;
        box-shadow: 0 0 0 1px rgba(249,115,22,0.15), var(--shadow-md);
      }
      .card-paars {
        border-top: 4px solid #a855f7;
        box-shadow: 0 0 0 1px rgba(168,85,247,0.15), var(--shadow-md);
      }
      .card-geel {
        border-top: 4px solid #eab308;
        box-shadow: 0 0 0 1px rgba(234,179,8,0.15), var(--shadow-md);
      }

      .badge-oranje { background-color: rgba(249,115,22,0.15); color: #fb923c; border: 1px solid rgba(249,115,22,0.3); }
      .badge-paars  { background-color: rgba(168,85,247,0.15); color: #c084fc; border: 1px solid rgba(168,85,247,0.3); }
      .badge-geel   { background-color: rgba(234,179,8,0.15);  color: #facc15; border: 1px solid rgba(234,179,8,0.3); }

      /* ── Shared table styles ── */
      .table-header-oranje {
        background: #f97316;
        color: #ffffff;
      }
      .table-header-paars {
        background: #a855f7;
        color: #ffffff;
      }
      .table-header-geel {
        background: #eab308;
        color: #1a1a2e;
      }

      .table-cell-oranje {
        background: rgba(249, 115, 22, 0.06);
      }
      .table-cell-paars {
        background: rgba(168, 85, 247, 0.06);
      }
      .table-cell-geel {
        background: rgba(234, 179, 8, 0.06);
      }

      /* ── Scroll-driven shadow hint on mobile ── */
      .table-scroll {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }

      /* ── Typography ── */
      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
        font-weight: 400;
        letter-spacing: -0.02em;
      }

      /* ── Source links ── */
      .source-link {
        color: var(--link-color);
      }
      .source-link:hover {
        color: var(--link-hover);
      }
    </style>
    <!-- Prevent flash of wrong theme (runs before render) -->
    <script is:inline>
      (function() {
        try {
          var stored = localStorage.getItem('theme');
          var isDark = stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches);
          if (isDark) document.documentElement.classList.add('dark');
        } catch(e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen antialiased transition-colors duration-300" style="font-family:var(--font-body);">
    <!-- Top navigation -->
    <nav class="sticky top-0 z-50 border-b transition-colors duration-300"
         style="background:var(--nav-bg); border-color:var(--nav-border); backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between">
        <a href="/" class="text-sm font-semibold tracking-tight no-underline" style="color:var(--text-heading);">
          Contactvoorkeuren kleuren
        </a>
        <ThemeToggle />
      </div>
    </nav>

    <slot />
  </body>
</html>
