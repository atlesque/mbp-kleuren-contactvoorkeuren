---
import Layout from '../layouts/Layout.astro';

const colors = [
  {
    emoji: '🟧',
    label: 'Oranje',
    subtitle: 'Vlaamse dienstverleningen (IPDC)',
    cardClass: 'card-oranje',
    badgeClass: 'badge-oranje',
    fields: [
      { term: 'Bron', def: 'Diensten uit de IPDC-productenlijst, opgehaald via notificaties' },
      { term: 'Juridisch kader', def: 'Valt onder het eGov-decreet' },
      { term: 'Rol MBP', def: 'Verwerkingsverantwoordelijke — MBP beheert de gegevens zelf' },
      { term: 'Consent', def: 'Burger geeft actief toestemming per dienstverlening' },
      { term: 'E-mailadres', def: 'Centraal opgeslagen in de Profielservice' },
      { term: 'E-mail verplicht?', def: 'Nee, maar kan als communicatiekanaal gevraagd worden' },
      { term: 'Voorbeeld', def: 'Diverse Vlaamse overheidsdiensten (Jobbonus, afvalkalender, …)' },
    ],
  },
  {
    emoji: '🟪',
    label: 'Paars',
    subtitle: 'Dienstencheques (DHC)',
    cardClass: 'card-paars',
    badgeClass: 'badge-paars',
    fields: [
      { term: 'Bron', def: 'Contract met een externe partner' },
      { term: 'Juridisch kader', def: 'Verwerkersovereenkomst met de partner' },
      { term: 'Rol MBP', def: 'Enkel verwerker — MBP verwerkt gegevens namens de partner' },
      { term: 'Consent', def: 'Toestemming voor communicatie is verplicht' },
      { term: 'E-mailadres', def: 'Verplicht bij activatie van de dienst' },
      { term: 'Voorbeeld', def: 'Vandaag enkel Dienstencheques (DHC)' },
    ],
  },
  {
    emoji: '🟨',
    label: 'Geel',
    subtitle: 'eBox',
    cardClass: 'card-geel',
    badgeClass: 'badge-geel',
    fields: [
      { term: 'Bron', def: 'Samenwerking met een externe partner' },
      { term: 'Juridisch kader', def: 'Gedeelde verwerkingsverantwoordelijkheid — MBP en partner delen de verantwoordelijkheid' },
      { term: 'Rol MBP', def: 'Volgt de regels die de partner oplegt' },
      { term: 'Consent', def: 'Toestemming voor communicatie is verplicht; contactgegeven verplicht opgeslagen door gebruik van de dienst' },
      { term: 'E-mailadres', def: 'Verplicht bij activatie' },
      { term: 'Voorbeeld', def: 'Vandaag enkel eBox' },
    ],
  },
];

const sources = [
  {
    label: 'FA Contactvoorkeuren 2026',
    href: 'https://vlaamseoverheid.atlassian.net/wiki/spaces/CON/pages/7951188009/FA+Contactvoorkeuren+2026',
  },
  {
    label: 'Contactvoorkeuren in MBP app',
    href: 'https://vlaamseoverheid.atlassian.net/wiki/spaces/MBPAPP/pages/7912652902/Contactvoorkeuren+in+MBP+app',
  },
];
---

<Layout title="Contactvoorkeuren kleuren">
  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-20">

    <!-- Header -->
    <header class="mb-12 sm:mb-16 fade-in-up">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium tracking-wider uppercase mb-4"
           style="background:rgba(255,255,255,0.08); color:rgba(255,255,255,0.5); border:1px solid rgba(255,255,255,0.12)">
        Mijn Burgerprofiel
      </div>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-white leading-tight">
        Contactvoorkeuren<br class="hidden sm:block" />
        <span style="color:rgba(255,255,255,0.7)"> kleuren</span>
      </h1>
      <p class="mt-4 text-base sm:text-lg max-w-2xl" style="color:rgba(255,255,255,0.55)">
        Een overzicht van de drie kleurtypen voor contactvoorkeuren in het Mijn Burgerprofiel,
        met hun juridisch kader, rol van MBP en consent-vereisten.
      </p>
    </header>

    <!-- Color cards -->
    <div class="grid gap-6 sm:gap-8 lg:grid-cols-3">
      {colors.map((color, i) => (
        <article
          class={`fade-in-up rounded-2xl p-6 sm:p-7 ${color.cardClass}`}
          style="background:rgba(255,255,255,0.05); backdrop-filter:blur(12px);"
        >
          <!-- Card header -->
          <div class="flex items-start gap-3 mb-5">
            <span class="text-3xl leading-none mt-0.5" aria-hidden="true">{color.emoji}</span>
            <div>
              <span class={`inline-block text-xs font-semibold px-2.5 py-0.5 rounded-full mb-1 ${color.badgeClass}`}>
                {color.label}
              </span>
              <h2 class="text-lg font-semibold text-white leading-snug">{color.subtitle}</h2>
            </div>
          </div>

          <!-- Definition list -->
          <dl class="space-y-3">
            {color.fields.map((field) => (
              <div class="dl-row">
                <dt class="text-xs font-medium uppercase tracking-wide mb-0.5">{field.term}</dt>
                <dd class="text-sm leading-relaxed">{field.def}</dd>
              </div>
            ))}
          </dl>
        </article>
      ))}
    </div>

    <!-- Key difference callout -->
    <div class="mt-10 sm:mt-12 fade-in-up rounded-2xl p-6 sm:p-8"
         style="background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.1); backdrop-filter:blur(12px);">
      <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color:rgba(255,255,255,0.4)">
        Kernverschil in één zin
      </p>
      <p class="text-base sm:text-lg font-medium leading-relaxed" style="color:rgba(255,255,255,0.85)">
        Bij <span class="font-bold text-orange-400">oranje</span> is MBP de baas over de data,
        bij <span class="font-bold text-purple-400">paars</span> verwerkt MBP enkel voor een partner,
        en bij <span class="font-bold text-yellow-400">geel</span> delen MBP en de partner de verantwoordelijkheid.
      </p>
    </div>

    <!-- Sources -->
    <footer class="mt-10 sm:mt-12 fade-in-up">
      <p class="text-xs font-semibold uppercase tracking-wider mb-3" style="color:rgba(255,255,255,0.35)">
        Bronnen
      </p>
      <ul class="flex flex-col sm:flex-row gap-2 sm:gap-4 flex-wrap">
        {sources.map((src) => (
          <li>
            <a
              href={src.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm transition-colors duration-200"
              style="color:rgba(255,255,255,0.45);"
              onmouseover="this.style.color='rgba(255,255,255,0.85)'"
              onmouseout="this.style.color='rgba(255,255,255,0.45)'"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              {src.label}
            </a>
          </li>
        ))}
      </ul>
    </footer>

  </main>
</Layout>
