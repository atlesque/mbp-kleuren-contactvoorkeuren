---
import ComparisonTable from '../components/ComparisonTable.astro';
import Layout from '../layouts/Layout.astro';

// ── Column definitions ──
const columns = [
  { key: 'oranje', label: 'Oranje', headerClass: 'table-header-oranje', cellClass: 'table-cell-oranje' },
  { key: 'paars',  label: 'Paars',  headerClass: 'table-header-paars',  cellClass: 'table-cell-paars'  },
  { key: 'geel',   label: 'Geel',   headerClass: 'table-header-geel',   cellClass: 'table-cell-geel'   },
];

// ── Row data ──
const rows = [
  { label: 'Bron',    group: '',       values: { oranje: 'Diensten uit de IPDC-productenlijst, opgehaald via notificaties', paars: 'Contract met een externe partner', geel: 'Samenwerking met een externe partner' } },
  { label: 'Voorbeeld', group: '',     values: { oranje: 'Diverse Vlaamse overheidsdiensten (Jobbonus, afvalkalender, …)', paars: 'Vandaag enkel Dienstencheques (DHC)', geel: 'Vandaag enkel eBox' } },
  { label: 'Juridisch kader', group: 'Algemeen', values: { oranje: 'Valt onder het eGov-decreet', paars: 'Verwerkersovereenkomst met de partner', geel: 'Gedeelde verwerkingsverantwoordelijkheid — MBP en partner delen de verantwoordelijkheid' } },
  { label: 'Rol MBP', group: 'Algemeen', values: { oranje: 'Verwerkingsverantwoordelijke — MBP beheert de gegevens zelf', paars: 'Enkel verwerker — MBP verwerkt gegevens namens de partner', geel: 'Volgt de regels die de partner oplegt' } },
  { label: 'Consent', group: 'Communicatie & Consent', values: { oranje: 'Burger geeft actief toestemming per dienstverlening', paars: 'Toestemming voor communicatie is verplicht', geel: 'Toestemming voor communicatie is verplicht; contactgegeven verplicht opgeslagen door gebruik van de dienst' } },
  { label: 'E-mailadres', group: 'Communicatie & Consent', values: { oranje: 'Centraal opgeslagen in de Profielservice', paars: 'Verplicht bij activatie van de dienst', geel: 'Verplicht bij activatie' } },
  { label: 'E-mail verplicht?', group: 'Communicatie & Consent', values: { oranje: 'Nee, maar kan als communicatiekanaal gevraagd worden', paars: null, geel: null } },
];

const groups = ['', 'Algemeen', 'Communicatie & Consent'];

// ── Sources ──
const sources = [
  { label: 'FA Contactvoorkeuren 2026', href: 'https://vlaamseoverheid.atlassian.net/wiki/spaces/CON/pages/7951188009/FA+Contactvoorkeuren+2026' },
  { label: 'Contactvoorkeuren in MBP app', href: 'https://vlaamseoverheid.atlassian.net/wiki/spaces/MBPAPP/pages/7912652902/Contactvoorkeuren+in+MBP+app' },
];
---

<Layout title="Contactvoorkeuren kleuren">
  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-4 sm:py-6 lg:py-8">

    <!-- Key difference callout -->
    <div class="mb-8 sm:mb-10 fade-in-up rounded-2xl p-6 sm:p-8"
         style="background:var(--callout-bg); border:1px solid var(--callout-border); backdrop-filter:blur(12px);">
      <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color:var(--text-dim);">
        Kernverschil in één zin
      </p>
      <p class="text-base sm:text-lg font-medium leading-relaxed" style="color:var(--text-body);">
        Bij <span class="font-bold" style="color:#f97316;">oranje</span> is MBP de baas over de data, bij <span class="font-bold" style="color:#a855f7;">paars</span> verwerkt MBP enkel voor een partner, en bij <span class="font-bold" style="color:#ca8a04;">geel</span> delen MBP en de partner de verantwoordelijkheid.
      </p>
    </div>

    <ComparisonTable {columns} {rows} {groups} />

    <!-- Sources -->
    <footer class="mt-8 sm:mt-10 fade-in-up">
      <p class="text-xs font-semibold uppercase tracking-wider mb-3" style="color:var(--text-dim);">
        Bronnen
      </p>
      <ul class="flex flex-col sm:flex-row gap-2 sm:gap-4 flex-wrap">
        {sources.map((src) => (
          <li>
            <a
              href={src.href}
              target="_blank"
              rel="noopener noreferrer"
              class="source-link inline-flex items-center gap-1.5 text-sm transition-colors duration-200"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              {src.label}
            </a>
          </li>
        ))}
      </ul>
    </footer>

  </main>
</Layout>
