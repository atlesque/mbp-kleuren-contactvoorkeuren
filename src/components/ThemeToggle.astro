---
// Three-state theme toggle: Light → Dark → Auto
---

<button
  id="theme-toggle"
  type="button"
  class="theme-toggle"
  aria-label="Toggle color mode"
  title="Toggle color mode"
>
  <span class="toggle-icon" id="toggle-icon">💻</span>
  <span class="toggle-label" id="toggle-label">Auto</span>
</button>

<script>
  const THEME_KEY = 'theme';
  const DARK_CLASS = 'dark';

  function getStoredTheme(): string | null {
    try {
      return localStorage.getItem(THEME_KEY);
    } catch {
      return null;
    }
  }

  function setStoredTheme(theme: string | null) {
    try {
      if (theme === 'auto' || theme === null) {
        localStorage.removeItem(THEME_KEY);
      } else {
        localStorage.setItem(THEME_KEY, theme);
      }
    } catch {
      // localStorage unavailable
    }
  }

  function getSystemPrefersDark(): boolean {
    return window.matchMedia('(prefers-color-scheme: dark)').matches;
  }

  function applyTheme(theme: string | null) {
    const isDark = theme === 'dark' || (theme !== 'light' && getSystemPrefersDark());
    document.documentElement.classList.toggle(DARK_CLASS, isDark);
  }

  function updateToggleUI(theme: string | null) {
    const icon = document.getElementById('toggle-icon');
    const label = document.getElementById('toggle-label');
    if (!icon || !label) return;

    if (theme === 'light') {
      icon.textContent = '☀️';
      label.textContent = 'Light';
    } else if (theme === 'dark') {
      icon.textContent = '🌙';
      label.textContent = 'Dark';
    } else {
      icon.textContent = '💻';
      label.textContent = 'Auto';
    }
  }

  // Cycle: auto → light → dark → auto
  function cycleTheme(current: string | null): string | null {
    if (current === 'light') return 'dark';
    if (current === 'dark') return null; // auto
    return 'light';
  }

  function init() {
    const stored = getStoredTheme();
    applyTheme(stored);
    updateToggleUI(stored);

    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const current = getStoredTheme();
      const next = cycleTheme(current);
      setStoredTheme(next);
      applyTheme(next);
      updateToggleUI(next);
    });

    // Listen for system preference changes (only relevant in auto mode)
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      const current = getStoredTheme();
      if (current !== 'light' && current !== 'dark') {
        applyTheme(null);
      }
    });
  }

  // Prevent flash of wrong theme
  (function() {
    try {
      const stored = localStorage.getItem('theme');
      const isDark = stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches);
      if (isDark) {
        document.documentElement.classList.add('dark');
      }
    } catch {
      // localStorage unavailable
    }
  })();

  document.addEventListener('DOMContentLoaded', init);
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid rgba(128, 128, 128, 0.3);
    background: rgba(128, 128, 128, 0.08);
    color: inherit;
    cursor: pointer;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1;
    transition: background 0.2s, border-color 0.2s;
  }
  .theme-toggle:hover {
    background: rgba(128, 128, 128, 0.16);
    border-color: rgba(128, 128, 128, 0.5);
  }
  .theme-toggle:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }
  .toggle-icon {
    font-size: 1rem;
    line-height: 1;
  }
</style>
