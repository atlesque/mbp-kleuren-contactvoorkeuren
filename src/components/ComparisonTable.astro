---
interface Column {
  key: string;
  label: string;
  headerClass: string;
  cellClass: string;
}

interface TableRow {
  label: string;
  group: string;
  values: Record<string, string | null>;
}

interface Props {
  columns: Column[];
  rows: TableRow[];
  groups: string[];
}

const { columns, rows, groups } = Astro.props;

// ── Group rows, inserting group-header sentinels ──
type GroupedRow = TableRow | { isGroupHeader: true; label: string };
const groupedRows: GroupedRow[] = [];

for (const group of groups) {
  const groupRows = rows.filter((r) => r.group === group);
  if (groupRows.length === 0) continue;
  if (group) groupedRows.push({ isGroupHeader: true, label: group });
  groupedRows.push(...groupRows);
}

function isGroupHeader(row: GroupedRow): row is { isGroupHeader: true; label: string } {
  return (row as any).isGroupHeader === true;
}

// ── Color mapping (avoids ternaries in template) ──
const colorMap: Record<string, { swatch: string; text: string }> = {
  oranje: { swatch: 'swatch-oranje', text: 'text-[#f97316]' },
  paars:  { swatch: 'swatch-paars',  text: 'text-[#a855f7]' },
  geel:   { swatch: 'swatch-geel',   text: 'text-[#ca8a04]' },
};
---

<!-- ═══════════ Desktop: table ═══════════ -->
<div class="hidden md:block fade-in-up table-scroll rounded-xl border"
     style="background:var(--surface-solid); border-color:var(--surface-border); box-shadow:var(--shadow-md); overflow:clip;">
  <table class="w-full min-w-160 text-sm border-collapse">
    <thead class="sticky z-20" style="top:3.5rem;">
      <tr>
        <th class="sticky left-0 z-10 w-40 sm:w-48 p-4 text-left text-xs font-semibold uppercase tracking-wider"
            style="background:var(--surface-solid); color:var(--text-dim); border-bottom:1px solid var(--table-border);">
          Kleur
        </th>
        {columns.map((col) => (
          <th class={`p-4 sm:p-5 text-center ${col.headerClass}`}
              style="border-bottom:1px solid var(--table-border);">
            <span class="text-xs font-bold uppercase tracking-wider">{col.label}</span>
          </th>
        ))}
      </tr>
    </thead>
    <tbody>
      {groupedRows.map((row) => {
        if (isGroupHeader(row)) {
          return (
            <tr>
              <td colspan={columns.length + 1}
                  class="px-4 py-2.5 text-xs font-semibold uppercase tracking-wider"
                  style="color:var(--text-dim); border-bottom:1px solid var(--table-border);">
                {row.label}
              </td>
            </tr>
          );
        }
        return (
          <tr style="border-bottom:1px solid var(--table-border);">
            <td class="sticky left-0 z-10 p-3 sm:p-4 text-xs font-semibold uppercase tracking-wide whitespace-nowrap"
                style="background:var(--surface-solid); color:var(--text-dim);">
              {row.label}
            </td>
            {columns.map((col) => (
              <td class={`p-3 sm:p-4 leading-relaxed align-top text-center text-xs sm:text-sm ${col.cellClass}`}
                  style="color:var(--text-body);">
                {row.values[col.key] ?? <span style="color:var(--text-dim);" aria-label="Niet van toepassing">&mdash;</span>}
              </td>
            ))}
          </tr>
        );
      })}
    </tbody>
  </table>
</div>

<!-- ═══════════ Mobile: cards ═══════════ -->
<div class="fade-in-up mobile-cards">
  {groups.map((group) => {
    const groupRows = rows.filter((r) => r.group === group);
    if (groupRows.length === 0) return null;
    return (
      <div class="flex flex-col gap-3">
        {group && (
          <p class="text-xs font-semibold uppercase tracking-wider px-1" style="color:var(--text-dim);">
            {group}
          </p>
        )}
        {groupRows.map((row) => (
          <div class="mobile-card">
            <div class="mobile-card__label">{row.label}</div>
            {columns.map((col) => {
              const val = row.values[col.key];
              const c = colorMap[col.key] ?? { swatch: '', text: '' };
              return (
                <div class="mobile-card__item">
                  <span class={`mobile-card__swatch ${c.swatch}`}></span>
                  <div class="flex-1 min-w-0">
                    <span class={`text-[0.6875rem] font-bold uppercase tracking-wider ${c.text}`}>{col.label}</span>
                    <p class="mt-0.5 text-[0.8125rem] leading-relaxed" style="color:var(--text-body);">
                      {val ?? <span style="color:var(--text-dim);">&mdash;</span>}
                    </p>
                  </div>
                </div>
              );
            })}
          </div>
        ))}
      </div>
    );
  })}
</div>
